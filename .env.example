# Adyen (test credentials from Customer Area)
# Merchant account: exact name from Adyen -> Account -> Merchant accounts (case-sensitive)
ADYEN_API_KEY=your_adyen_api_key
ADYEN_CLIENT_KEY=your_adyen_client_key
ADYEN_MERCHANT_ACCOUNT=your_merchant_account
ADYEN_ENVIRONMENT=test
# Required to enable mutating Adyen Management API endpoints.
# Send this value in the X-Admin-Token header when making admin updates.
ADYEN_MANAGEMENT_ADMIN_TOKEN=generate_a_long_random_admin_token

# Xendit (for Thailand BAY/Krungsri etc - Business ID from Dashboard -> Settings -> Business)
# XENDIT_DESTINATION_ACCOUNT_ID=your-business-id

# Optional
# SECRET_KEY=your-secret-key
# FLASK_DEBUG=1
