# Adyen (test credentials from Customer Area)
# Merchant account: exact name from Adyen → Account → Merchant accounts (case-sensitive)
ADYEN_API_KEY=your-adyen-api-key
ADYEN_CLIENT_KEY=your-adyen-client-key
ADYEN_MERCHANT_ACCOUNT=your-merchant-account
ADYEN_ENVIRONMENT=test

# Required for Adyen Management PATCH endpoints.
# Generate a long random value and send it as a Bearer token or
# X-Adyen-Management-Write-Token when performing admin writes.
ADYEN_MANAGEMENT_WRITE_TOKEN=your-management-write-token

# Xendit (for Thailand BAY/Krungsri etc - Business ID from Dashboard → Settings → Business)
# XENDIT_DESTINATION_ACCOUNT_ID=your-business-id

# Optional
# SECRET_KEY=your-secret-key
# FLASK_DEBUG=1
